# ── Local development (no relay, no tunnel) ──────────────────
# Default: /tmp/opencode-relay
# Just run opencode-connected — it writes registration files here
# and the MCP server reads them.
# RELAY_REGISTRY_DIR=/tmp/opencode-relay

# ── Relay deployment (SSH tunnel to remote machine) ──────────
# SSH command to reach the relay (enables tunneling).
# If unset, opencode-connected runs in local-only mode.
# RELAY_SSH_CMD=gcloud compute ssh mcp-gateway --zone=us-central1-a --project=your-project --
# RELAY_SSH_CMD=ssh user@relay.example.com

# Registry dir on the relay (override if different from local default)
# RELAY_REGISTRY_DIR=/var/lib/opencode-relay

# ── MCP server settings ─────────────────────────────────────
# How often to refresh instance list (ms)
# DISCOVERY_INTERVAL_MS=30000

# Timeout for health-checking each instance (ms)
# HEALTH_CHECK_TIMEOUT_MS=3000

# Transport backend: "local-relay" | "tailscale" (future)
# TRANSPORT=local-relay

# ── Optional: HTTP auth (only needed if opencode binds to 0.0.0.0) ─
# Not needed when binding to 127.0.0.1 (default) with SSH tunnels.
# OPENCODE_SERVER_PASSWORD=your-secret
# OPENCODE_SERVER_USERNAME=opencode
