{
  "name": "@klutometis/opencode-mcp",
  "version": "1.0.9",
  "description": "MCP server for orchestrating OpenCode instances across machines via SSH reverse tunnels",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencode-mcp": "dist/index.js",
    "opencode-connected": "scripts/opencode-connected"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klutometis/opencode-mcp.git"
  },
  "keywords": [
    "mcp",
    "opencode",
    "ai",
    "coding-assistant",
    "remote",
    "ssh"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opencode-ai/sdk": "^1.2.26",
    "opencode-ai": "*",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
